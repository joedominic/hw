# Git ignore rules 
# Python cache and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Django specific
*.log
*.pot
*.py,cover
db.sqlite3
db.sqlite3-*
media/
staticfiles/

# Environment variables
.env
*.env

# Virtual environment
venv/
env/
.venv/
ENV/

# IDE / Editor settings
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS-specific files
.DS_Store
Thumbs.db

# Coverage reports
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml

# Migrations (optional — keep if you want to track them)
# */migrations/*.py
# !*/migrations/__init__.py
